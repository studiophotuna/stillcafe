# ----- Supabase -----
# From your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key (server only — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----- App -----
# Public base URL of the deployed site (used for payment redirect URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----- PayMongo -----
# From your PayMongo dashboard: Developers > API Keys
# Secret key is used server-side to create checkout sessions.
# Format: sk_test_... (sandbox) or sk_live_... (production)
PAYMONGO_SECRET_KEY=your-paymongo-secret-key
# Webhook signing secret (Developers > Webhooks)
PAYMONGO_WEBHOOK_SECRET=your-paymongo-webhook-secret
